rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FUNCIONES DE AYUDA (SEGURIDAD MILITAR 2026) ---
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().get('role', 'none') == role;
    }

    function isAdmin() { return hasRole('admin'); }
    function isTeacher() { return hasRole('teacher'); }
    
    // Lista Blanca de Administradores Maestros (Inmutable)
    function isRoot(userId) {
      let email = get(/databases/$(database)/documents/users/$(userId)).data.email;
      return email == 'antonio_rburgos@msn.com' || email == 'jarbugos40@gmail.com';
    }

    // Validación de Sanitización (Anti-Injection)
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen && !val.matches('.*<script.*');
    }

    // --- REGLAS DE PROTECCIÓN ATÓMICA ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId 
                    && request.resource.data.role != 'admin'; // No auto-admin
      
      allow update: if (isOwner(userId) || isAdmin()) 
                    && (!isRoot(userId) || (request.auth.uid == userId))
                    // Solo el Root puede cambiar roles a admin
                    && (request.resource.data.role == resource.data.role || isRoot(request.auth.uid))
                    // Sanitización de campos críticos
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['fullName']) 
                        || isValidString(request.resource.data.fullName, 100));
      
      allow delete: if isAdmin() && !isRoot(userId);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid 
                    && request.resource.data.amount is number;
      allow update, delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isTeacher() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid 
                    && request.resource.data.score is number;
      allow update, delete: if isAdmin();
    }

    match /classrooms/{classId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated(); 
      allow write: if isAdmin();
    }

    match /system/{configId} {
      allow read: if true;
      allow write: if isRoot(request.auth.uid); // Solo root toca configuración de sistema
    }

    match /admin_audit/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Permitir logs de sistema
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}